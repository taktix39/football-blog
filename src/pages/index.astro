---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import ArticleCard from '../components/ArticleCard.astro'
import { getMatches } from '../lib/microcms'
import { LEAGUE_LABELS } from '../types/microcms'
import type { League } from '../types/microcms'

// リーグフィルタをURLパラメータから取得
const league = Astro.url.searchParams.get('league') ?? 'all'

const { contents: matches, totalCount } = await getMatches({
  league: league !== 'all' ? league : undefined,
  limit: 100,
})
---

<BaseLayout currentLeague={league}>
  <div class="page-header">
    <h1 class="page-title">
      {league === 'all'
        ? '観戦記録'
        : <><em>{LEAGUE_LABELS[league as League] ?? league}</em></>
      }
    </h1>
    <span class="page-count">{matches.length} matches</span>
  </div>

  {matches.length === 0 ? (
    <p style="color: var(--text-tertiary); font-size: 14px; margin-top: 40px; text-align: center;">
      まだ記録がありません
    </p>
  ) : (
    <div class="article-list">
      {matches.map(match => <ArticleCard match={match} />)}
    </div>
  )}
</BaseLayout>
